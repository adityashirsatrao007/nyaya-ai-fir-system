HF_IMAGE_DEEPFAKE_MODEL_ID=dima806/deepfake_vs_real_image_detection
HF_IMAGE_DEEPFAKE_THRESHOLD=0.35
DEEPFAKE_VIDEO_FRAME_LIMIT=6

# Optional FIR OCR enhancement with Hugging Face TrOCR
HF_OCR_ENABLE_TROCR=true
HF_OCR_MODEL_ID=microsoft/trocr-base-printed
HF_OCR_MAX_EDGE=1400

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional Roboflow evidence enrichment
ROBOFLOW_API_URL=https://detect.roboflow.com
ROBOFLOW_MODEL_ID=
ROBOFLOW_PROJECT_ID=
ROBOFLOW_VERSION=
ROBOFLOW_API_KEY=
